      </div>
    </div>
  </nav>
  </header>

  <!-- Main Content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <h4>🏆 SportsBanquetGuide</h4>
