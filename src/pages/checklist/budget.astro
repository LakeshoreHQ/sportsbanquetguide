---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Sports Banquet Budget Worksheet" description="Free printable budget worksheet for high school sports banquets. Track venue, catering, decorations, centerpieces, awards, and more. Downloadable PDF for coaches and booster clubs.">
  <div class="breadcrumbs">
    <div class="container">
      <a href="/">Home</a> <span>/</span> <a href="/checklist/">Checklist</a> <span>/</span> <strong>Budget Worksheet</strong>
    </div>
  </div>

  <section class="page-header">
    <div class="container">
      <h1>Sports Banquet Budget Worksheet</h1>
      <p>A complete budget tracking tool for your high school athletic celebration. Estimate costs, track spending, and stay on target.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="page-wrapper">
        <h2>Budget Estimator</h2>
        <p>Use the worksheet below to estimate each expense category. Average costs are provided as a starting point based on typical high school sports banquets.</p>

        <h3>Venue & Space</h3>
        <table style="width:100%;border-collapse:collapse;margin:1rem 0;">
          <tr style="background:var(--primary);color:white;"><th style="padding:0.5rem;text-align:left;">Item</th><th style="padding:0.5rem;text-align:left;">Avg Cost</th><th style="padding:0.5rem;text-align:left;">Your Budget</th><th style="padding:0.5rem;text-align:left;">Actual</th></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">School Gym/Cafeteria (free)</td><td style="padding:0.5rem;">$0</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Banquet Hall Rental</td><td style="padding:0.5rem;">$300-800</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Restaurant Private Room</td><td style="padding:0.5rem;">$0-200 (min spend)</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Community Center</td><td style="padding:0.5rem;">$100-400</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
        </table>

        <h3>Catering & Food</h3>
        <table style="width:100%;border-collapse:collapse;margin:1rem 0;">
          <tr style="background:var(--primary);color:white;"><th style="padding:0.5rem;text-align:left;">Item</th><th style="padding:0.5rem;text-align:left;">Avg Cost</th><th style="padding:0.5rem;text-align:left;">Your Budget</th><th style="padding:0.5rem;text-align:left;">Actual</th></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Catered Dinner (per person)</td><td style="padding:0.5rem;">$12-25</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Buffet Style (per person)</td><td style="padding:0.5rem;">$8-15</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Dessert/Cake</td><td style="padding:0.5rem;">$30-100</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Drinks/Beverages</td><td style="padding:0.5rem;">$20-60</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Paper Goods (plates, cups, etc.)</td><td style="padding:0.5rem;">$15-30</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
        </table>

        <h3>Decorations & Centerpieces</h3>
        <table style="width:100%;border-collapse:collapse;margin:1rem 0;">
          <tr style="background:var(--primary);color:white;"><th style="padding:0.5rem;text-align:left;">Item</th><th style="padding:0.5rem;text-align:left;">Avg Cost</th><th style="padding:0.5rem;text-align:left;">Your Budget</th><th style="padding:0.5rem;text-align:left;">Actual</th></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Table Centerpieces (each)</td><td style="padding:0.5rem;">$15-45</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Custom 3D Printed Centerpieces</td><td style="padding:0.5rem;">$25-55</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Tablecloths & Linens</td><td style="padding:0.5rem;">$50-150</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Banners & Wall Decor</td><td style="padding:0.5rem;">$20-80</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Photo Backdrop & Props</td><td style="padding:0.5rem;">$25-75</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
        </table>

        <h3>Awards & Recognition</h3>
        <table style="width:100%;border-collapse:collapse;margin:1rem 0;">
          <tr style="background:var(--primary);color:white;"><th style="padding:0.5rem;text-align:left;">Item</th><th style="padding:0.5rem;text-align:left;">Avg Cost</th><th style="padding:0.5rem;text-align:left;">Your Budget</th><th style="padding:0.5rem;text-align:left;">Actual</th></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Trophies / Plaques (each)</td><td style="padding:0.5rem;">$10-35</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Certificates / Printing</td><td style="padding:0.5rem;">$15-40</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Medals / Ribbons (each)</td><td style="padding:0.5rem;">$3-8</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Senior Gifts (each)</td><td style="padding:0.5rem;">$5-25</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
        </table>

        <h3>Media & Misc</h3>
        <table style="width:100%;border-collapse:collapse;margin:1rem 0;">
          <tr style="background:var(--primary);color:white;"><th style="padding:0.5rem;text-align:left;">Item</th><th style="padding:0.5rem;text-align:left;">Avg Cost</th><th style="padding:0.5rem;text-align:left;">Your Budget</th><th style="padding:0.5rem;text-align:left;">Actual</th></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Photography / Videography</td><td style="padding:0.5rem;">$0-200</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Slideshow / AV Production</td><td style="padding:0.5rem;">$0-50</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Invitations / Programs</td><td style="padding:0.5rem;">$20-80</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Contingency (10-15%)</td><td style="padding:0.5rem;">$50-200</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
        </table>

        <div class="product-note">
          <p><strong>💡 Centerpiece Tip:</strong> Custom 3D printed sports centerpieces range from $25-55 each depending on sport and personalization. They double as keepsakes that athletes and families take home — something generic banquet supplies can't do. <a href="https://lakeshore-gift.myshopify.com/collections/all" target="_blank">Browse available designs →</a></p>
        </div>

        <h2>Total Budget Summary</h2>
        <table style="width:100%;border-collapse:collapse;margin:1rem 0;">
          <tr style="background:var(--primary);color:white;"><th style="padding:0.5rem;text-align:left;">Category</th><th style="padding:0.5rem;text-align:left;">Budget Total</th><th style="padding:0.5rem;text-align:left;">Actual Total</th></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Venue & Space</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Catering & Food</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Decorations & Centerpieces</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Awards & Recognition</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="border-bottom:1px solid var(--border);"><td style="padding:0.5rem;">Media & Misc</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
          <tr style="font-weight:bold;background:#fffbeb;"><td style="padding:0.5rem;">GRAND TOTAL</td><td style="padding:0.5rem;">$_____</td><td style="padding:0.5rem;">$_____</td></tr>
        </table>

        <h2>Fundraising Ideas</h2>
        <ul>
          <li><strong>Spirit Wear Sales</strong> — Sell team apparel with a portion going to banquet fund</li>
          <li><strong>Concession Stand</strong> — Staff games throughout the season</li>
          <li><strong>Car Wash</strong> — Classic fundraiser, low overhead</li>
          <li><strong>Team Photo Sales</strong> — Partner with a photographer for commission</li>
          <li><strong>Booster Club Donations</strong> — Many businesses sponsor athletic events</li>
        </ul>

        <p style="margin-top:2rem;"><a href="/checklist/" class="btn btn-primary">Back to Main Checklist →</a></p>
      </div>
    </div>
  </section>
</MainLayout>
