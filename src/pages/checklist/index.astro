---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="High School Sports Banquet Planning Checklist" description="Free printable high school sports banquet planning checklist. Complete timeline from 8 weeks out to event day. Downloadable PDF for coaches and booster clubs.">
  <div class="breadcrumbs">
    <div class="container">
      <a href="/">Home</a> <span>/</span> <strong>Banquet Planning Checklist</strong>
    </div>
  </div>

  <section class="page-header">
    <div class="container">
      <h1>The Ultimate Sports Banquet Planning Checklist</h1>
      <p>Your master timeline. Print it, share it with your committee, and check off items as you go.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="page-wrapper">
        <h2>8 Weeks Before the Banquet</h2>
        <div class="checklist-item"><input type="checkbox" /> Set date and time</div>
        <div class="checklist-item"><input type="checkbox" /> Determine budget per person</div>
        <div class="checklist-item"><input type="checkbox" /> Form planning committee</div>
        <div class="checklist-item"><input type="checkbox" /> Choose venue</div>
        <div class="checklist-item"><input type="checkbox" /> Reserve venue</div>

        <h2>6 Weeks Before</h2>
        <div class="checklist-item"><input type="checkbox" /> Send save-the-date or invitations</div>
        <div class="checklist-item"><input type="checkbox" /> Order custom centerpieces (allow 2-3 weeks production)</div>
        <div class="checklist-item"><input type="checkbox" /> Choose menu/caterer</div>
        <div class="checklist-item"><input type="checkbox" /> Decide award categories</div>
        <div class="checklist-item"><input type="checkbox" /> Order awards, trophies, or certificates</div>

        <h2>4 Weeks Before</h2>
        <div class="checklist-item"><input type="checkbox" /> Confirm venue details</div>
        <div class="checklist-item"><input type="checkbox" /> Finalize menu</div>
        <div class="checklist-item"><input type="checkbox" /> Order additional decorations</div>
        <div class="checklist-item"><input type="checkbox" /> Arrange photography/video</div>
        <div class="checklist-item"><input type="checkbox" /> Create program or slideshow</div>

        <h2>2 Weeks Before</h2>
        <div class="checklist-item"><input type="checkbox" /> Confirm RSVP count</div>
        <div class="checklist-item"><input type="checkbox" /> Assign seating arrangements</div>
        <div class="checklist-item"><input type="checkbox" /> Prepare award scripts</div>
        <div class="checklist-item"><input type="checkbox" /> Rehearse program flow</div>
        <div class="checklist-item"><input type="checkbox" /> Confirm AV equipment</div>

        <h2>1 Week Before</h2>
        <div class="checklist-item"><input type="checkbox" /> Pick up centerpieces</div>
        <div class="checklist-item"><input type="checkbox" /> Confirm all vendors</div>
        <div class="checklist-item"><input type="checkbox" /> Shop for table supplies</div>
        <div class="checklist-item"><input type="checkbox" /> Prepare photo displays</div>

        <h2>3 Days Before</h2>
        <div class="checklist-item"><input type="checkbox" /> Final run-through with committee</div>
        <div class="checklist-item"><input type="checkbox" /> Pack emergency kit (safety pins, tape, markers)</div>
        <div class="checklist-item"><input type="checkbox" /> Confirm all speakers</div>

        <h2>1 Day Before</h2>
        <div class="checklist-item"><input type="checkbox" /> Set up venue</div>
        <div class="checklist-item"><input type="checkbox" /> Arrange tables and centerpieces</div>
        <div class="checklist-item"><input type="checkbox" /> Test AV equipment</div>
        <div class="checklist-item"><input type="checkbox" /> Set up photo area</div>

        <h2>Day Of</h2>
        <div class="checklist-item"><input type="checkbox" /> Final venue setup</div>
        <div class="checklist-item"><input type="checkbox" /> Confirm food/catering timing</div>
        <div class="checklist-item"><input type="checkbox" /> Welcome guests</div>
        <div class="checklist-item"><input type="checkbox" /> Run the program</div>
        <div class="checklist-item"><input type="checkbox" /> Celebrate!</div>

        <p style="margin-top:2rem;text-align:center;">
          <a href="/banquet-planning/" class="btn btn-primary">Read the Full Banquet Planning Guide →</a>
          <a href="/decorations/" class="btn btn-outline" style="margin-left:0.5rem;">Decoration Ideas →</a>
        </p>
      </div>
    </div>
  </section>
</MainLayout>
