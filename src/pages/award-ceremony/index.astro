import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="High School Athletic Award Ceremony Planning Guide" description="Plan a meaningful high school athletic award ceremony. Award categories, presentation tips, decoration ideas, and custom centerpieces for athletic departments and booster clubs.">
  <div class="breadcrumbs">
    <div class="container">
      <a href="/">Home</a> <span>/</span> <strong>Award Ceremony Guide</strong>
    </div>
  </div>

  <section class="page-header">
    <div class="container">
      <h1>The Complete Athletic Award Ceremony Planning Guide</h1>
      <p>An athletic award ceremony is more than a formality. It's the program's opportunity to reinforce values and send every athlete into the offseason feeling valued.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="page-wrapper">
        <h2>Award Categories That Matter</h2>
        
        <h3>Participation / Team Awards (for every athlete)</h3>
        <ul>
          <li>Varsity Letter</li>
          <li>Team Photo or Memory Card</li>
          <li>Certificate of Participation</li>
        </ul>

        <h3>Performance Awards</h3>
        <ul>
          <li>Most Valuable Player (MVP)</li>
          <li>Most Improved Player</li>
          <li>Offensive Player of the Year</li>
          <li>Defensive Player of the Year</li>
          <li>Rookie of the Year</li>
        </ul>

        <h3>Character Awards</h3>
        <ul>
          <li>Coach's Award (heart of the team)</li>
          <li>Leadership Award</li>
          <li>Sportsmanship Award</li>
          <li>Teammate of the Year</li>
          <li>Academic All-Conference</li>
        </ul>

        <h3>Special Awards</h3>
        <ul>
          <li>Four-Year Letterman Recognition</li>
          <li>Senior Appreciation</li>
          <li>Program Record Holders</li>
        </ul>

        <h2>Structuring the Ceremony</h2>
        <p>The best award ceremonies follow a logical flow that builds energy. Start with team/participation awards, move to character awards, build to performance awards, and close with the special recognitions. This ensures every athlete receives recognition while creating a natural crescendo to the MVP moment.</p>

        <h2>Award Table Setup</h2>
        <p>The awards table is the visual centerpiece of your ceremony. Arrange awards in order of presentation, allow space for photographers, and use decorative elements that reflect your sport.</p>

        <div class="product-note">
          <p><strong>🏅 Awards Table Centerpieces:</strong> A custom 3D printed sports centerpiece on the awards table adds a professional, polished look and reinforces your team's identity throughout the ceremony.</p>
          <a href="https://lakeshore-gift.myshopify.com/collections/all" class="btn btn-outline" target="_blank">View Awards Table Centerpieces →</a>
        </div>

        <h2>Presenting Awards: Tips for Coaches</h2>
        <ul>
          <li><strong>Be specific</strong> — Instead of "great season," mention a specific game or moment</li>
          <li><strong>Keep it moving</strong> — 30-60 seconds per award keeps energy up</li>
          <li><strong>Balance emotion</strong> — Celebrate wins but honor effort equally</li>
          <li><strong>Involve assistant coaches</strong> — Let them present awards they helped determine</li>
        </ul>

        <p><a href="/banquet-planning/" class="btn btn-outline">Read the Full Banquet Planning Guide →</a></p>
      </div>
    </div>
  </section>
</MainLayout>

