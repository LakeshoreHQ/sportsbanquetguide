---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Sports Banquet Planning Blog — Expert Tips & Ideas" description="Expert articles on high school sports banquet planning, senior night ceremonies, award categories, decoration ideas, and celebration tips from SportsBanquetGuide.com.">
  <div class="breadcrumbs">
    <div class="container">
      <a href="/">Home</a> <span>/</span> <strong>Blog</strong>
    </div>
  </div>

  <section class="page-header">
    <div class="container">
      <h1>📝 Sports Banquet Planning Blog</h1>
      <p>Expert tips, ideas, and guides to help you plan unforgettable high school sports celebrations.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="page-wrapper">
        <h2><span class="section-emoji">📰</span>Latest Articles</h2>
        <div class="section-title-underline" style="margin:0.5rem auto 2rem;"></div>
        <div style="display:grid;gap:2rem;margin-top:1.5rem;">
          <div class="card">
            <div class="card-icon">👩</div>
            <h3>Team Mom's Guide to Planning a Sports Banquet</h3>
            <p>A step-by-step guide written specifically for team moms. Packing lists, timeline templates, decoration shortcuts, and centerpiece ideas.</p>
            <a href="/blog/team-mom-guide/" class="card-link">Read Article →</a>
          </div>
          <div class="card">
            <div class="card-icon">🏆</div>
            <h3>10 Award Categories Every Sports Banquet Should Include</h3>
            <p>From MVP to the Unsung Hero — learn the award categories that make every athlete feel recognized, plus creative names and presentation ideas.</p>
            <a href="/blog/award-categories/" class="card-link">Read Article →</a>
          </div>
          <div class="card">
            <div class="card-icon">🗓️</div>
            <h3>The Ultimate 8-Week Banquet Planning Timeline</h3>
            <p>Week-by-week breakdown of everything you need to do to plan a successful sports banquet. Never miss a deadline again.</p>
            <a href="/blog/banquet-timeline/" class="card-link">Read Article →</a>
          </div>
          <div class="card">
            <div class="card-icon">🎤</div>
            <h3>Coach's Speech Template & Tips</h3>
            <p>A proven speech structure that balances recognition, inspiration, and team pride. Includes a fill-in-the-blank template.</p>
            <a href="/blog/coach-speech/" class="card-link">Read Article →</a>
          </div>
          <div class="card">
            <div class="card-icon">🎨</div>
            <h3>15 Easy & Affordable Banquet Decoration Ideas</h3>
            <p>Budget-friendly decoration ideas that transform a plain banquet hall into a celebration your athletes and families will love.</p>
            <a href="/blog/decoration-ideas/" class="card-link">Read Article →</a>
          </div>
          <div class="card">
            <div class="card-icon">🎓</div>
            <h3>Senior Night Ceremony Script & Planning Guide</h3>
            <p>A complete script for senior night, including parent speech structure, coach remarks, and the special moments families remember forever.</p>
            <a href="/blog/senior-night-script/" class="card-link">Read Article →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
